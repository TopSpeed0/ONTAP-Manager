# Python virtual environment (used for PDF extraction tools)
.venv/

# Local config with real cluster names, IPs, paths (template is tracked)
config.json

# Generated HTML (loads from config.json — not for git)
*.html

# PDF files are large — track separately or exclude from git
PDF/*.pdf

# MCP config contains sensitive credentials (Telegram session string, API keys)
.vscode/mcp.json

# Ansible Vault encrypted credential files (keep vault_template.yml tracked)
ansible/s3-bucket-provision/credentials/vault_credentials*.yml

# Credential store — only scripts are tracked, not keys or encrypted files
credentials/aes.key
credentials/*.cred

# IDE settings
.vscode/

# Claude local settings
.claude/

# Site-specific DR reports (too coupled to local cluster topology)
scripts/reports/Get-NI-DR-Report*.ps1
Get-NI-DR-Report*.ps1
