# Python virtual environment (used for PDF extraction tools)
.venv/

# Local config with real cluster names, IPs, paths (template is tracked)
config.json

# Generated HTML (loads from config.json — not for git)
*.html
# Exception: docs hub SPA is tracked (cluster data injected at runtime from config.json)
!docs/index.html

# PDF files are large — track separately or exclude from git
PDF/*.pdf

# MCP config contains sensitive credentials (Telegram session string, API keys)
.vscode/mcp.json

# Ansible Vault encrypted credential files (keep vault_template.yml tracked)
credentials/vault_credentials*.yml

# Site-specific Ansible playbooks (contain real hostnames/IPs — generic version is tracked)
ansible/s3-bucket-provision/provision_s3_bucket.yml
ansible/s3-bucket-provision/provision_s3_bucket_admin.yml
ansible/s3-bucket-provision/provision_s3_bucket_dev.yml
ansible/s3-bucket-provision/README.md
ansible/s3-bucket-provision/_provision_vars.json
ansible/s3-bucket-provision/_vault_pass.tmp

# Credential store — only scripts are tracked, not keys or encrypted files
credentials/aes.key
credentials/*.cred

# IDE settings
.vscode/

# Claude local settings
.claude/

# Site-specific DR reports (too coupled to local cluster topology)
scripts/reports/Get-NI-DR-Report*.ps1

# Personal NetApp support cases (raw, contain customer name + internal links)
.github/Netapp Cases/

# Session logs (personal working notes)
.github/session-log*.md

# Generated CSV reports (contain real cluster/volume data)
*.csv

# Old quota report (superseded by Clusters Quota Policy Manger.ps1)
scripts/quota/Clusters Quota Reports (old).ps1
Get-NI-DR-Report*.ps1
